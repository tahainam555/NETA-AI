# Allowed frontend origin. Use a comma-separated list for multiple origins.
FRONTEND_URL=http://localhost:3000

# Server-only secrets
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
RESEND_SERVER_TOKEN=your_resend_server_token
CONTACT_FROM_EMAIL=verified-sender@example.com
CONTACT_TO_EMAIL=neta.ai.pk@gmail.com

# Private production URL from the n8n Webhook node. Never expose this in frontend variables.
N8N_WEBHOOK_URL=https://your-n8n-host.example/webhook/neta-ai-audit

# Optional local Ollama enhancement. Rule-based recommendations remain the default.
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
